[Icon Theme]
Name=Dark-Gothic-Red
Comment=Dark Gothic Red icon overrides (Nerd Font glyph SVGs). Falls back to PlaneDark for anything not overridden.
Inherits=PlaneDark,hicolor
Directories=scalable/places,scalable/mimetypes,scalable/emblems

[scalable/places]
Context=Places
Size=64
MinSize=16
MaxSize=512
Type=Scalable

[scalable/mimetypes]
Context=MimeTypes
Size=64
MinSize=16
MaxSize=512
Type=Scalable

[scalable/emblems]
Context=Emblems
Size=64
MinSize=8
MaxSize=512
Type=Scalable
